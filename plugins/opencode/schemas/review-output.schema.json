{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenCode Review Output",
  "description": "Schema for structured review output from OpenCode. Made by Alejandro Apodaca Cordova (apoapps.com)",
  "type": "object",
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "needs-attention"]
    },
    "summary": {
      "type": "string",
      "description": "One paragraph overall assessment"
    },
    "model": {
      "type": "string",
      "description": "Model used for the review"
    },
    "fallbackUsed": {
      "type": "boolean",
      "description": "Whether a fallback model was used"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "file": { "type": "string" },
          "line_start": { "type": "integer" },
          "line_end": { "type": "integer" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "recommendation": { "type": "string" }
        },
        "required": ["severity", "title", "body"]
      }
    },
    "next_steps": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["verdict", "summary", "findings"]
}
